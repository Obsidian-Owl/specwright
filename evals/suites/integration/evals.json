{
  "suite": "integration",
  "version": "1.0",
  "evals": [
    {
      "id": "design-to-plan-handoff",
      "layer": "integration",
      "sequence": ["sw-design", "sw-plan"],
      "prompt_args": {"problem_statement": "Add rate limiting to the API gateway"},
      "seed": {
        "type": "fixture",
        "path": "suites/integration/fixtures/design-to-plan"
      },
      "expectations": [
        {
          "type": "state_transition",
          "expected_sequence": ["designing", "planning"],
          "description": "State transitions from designing to planning"
        },
        {
          "type": "snapshot_file_exists",
          "path": ".specwright/work/test-work/stage-report.md",
          "snapshot_index": 0,
          "description": "sw-design writes stage-report before handoff"
        },
        {
          "type": "snapshot_file_contains",
          "path": ".specwright/work/test-work/stage-report.md",
          "pattern": "^Attention required:",
          "snapshot_index": 0,
          "description": "sw-design stage report starts with attention-required"
        },
        {
          "type": "step_transcript_final_block",
          "step_index": 0,
          "line_patterns": [
            "^Done\\.\\s+.+\\.$",
            "^Artifacts:\\s+.+/$",
            "^Next:\\s+/sw-[a-z\\-]+$"
          ],
          "forbidden_substrings": [
            "Decision Digest",
            "Quality Checks",
            "Deficiencies",
            "### Recommendation"
          ],
          "description": "sw-design emits machine-parseable three-line handoff"
        },
        {
          "type": "model_grade",
          "rubric": "The transcript shows a concise design handoff. It should confirm completion, point to the stage-report artifact, and make the next stage explicit without inlining the full report. Score 0.8+ for a tight operational handoff, 0.5-0.7 for partial structure, below 0.5 for vague or overly long transitions.",
          "target": "$TRANSCRIPT",
          "description": "Transcript quality for design-to-plan handoff"
        },
        {
          "type": "artifact_reference",
          "source": ".specwright/work/test-work/design.md",
          "target": ".specwright/work/test-work/spec.md",
          "check": "headings_referenced",
          "description": "Spec references design section headings"
        },
        {
          "type": "file_exists",
          "path": ".specwright/work/test-work/spec.md",
          "description": "Spec artifact produced by plan"
        },
        {
          "type": "model_grade",
          "rubric": "Spec acceptance criteria are concrete and testable. Each criterion maps to a design decision. No vague language like 'should work correctly'.",
          "target": ".specwright/work/test-work/spec.md",
          "description": "Spec quality at handoff"
        }
      ],
      "tags": ["integration", "design-plan", "handoff"]
    },
    {
      "id": "plan-to-build-handoff",
      "layer": "integration",
      "sequence": ["sw-plan", "sw-build"],
      "prompt_args": {},
      "seed": {
        "type": "fixture",
        "path": "suites/integration/fixtures/plan-to-build"
      },
      "expectations": [
        {
          "type": "state_transition",
          "expected_sequence": ["planning", "building"],
          "description": "State transitions from planning to building"
        },
        {
          "type": "snapshot_file_exists",
          "path": ".specwright/work/test-work/stage-report.md",
          "snapshot_index": 0,
          "description": "sw-plan writes stage-report before handoff"
        },
        {
          "type": "step_transcript_final_block",
          "step_index": 0,
          "line_patterns": [
            "^Done\\.\\s+.+\\.$",
            "^Artifacts:\\s+.+/$",
            "^Next:\\s+/sw-[a-z\\-]+$"
          ],
          "description": "sw-plan emits machine-parseable three-line handoff"
        },
        {
          "type": "artifact_reference",
          "source": ".specwright/work/test-work/spec.md",
          "target": "tests/rate-limiter.test.ts",
          "check": "ids_referenced",
          "description": "Test file references spec criteria IDs"
        },
        {
          "type": "file_exists",
          "path": "src/middleware/rate-limiter.ts",
          "description": "Implementation file created by build"
        },
        {
          "type": "model_grade",
          "rubric": "The plan.md contains a clear task breakdown with ordered tasks, a file change map listing specific file paths, and respects dependency ordering between tasks. Tasks are small enough to be individually testable. Score 0.8+ if all three elements present with specific paths, 0.5-0.7 if partial, below 0.5 if missing.",
          "target": ".specwright/work/test-work/plan.md",
          "description": "Plan decomposition quality"
        }
      ],
      "tags": ["integration", "plan-build", "handoff"]
    },
    {
      "id": "build-to-verify-handoff",
      "layer": "integration",
      "sequence": ["sw-build", "sw-verify"],
      "prompt_args": {},
      "seed": {
        "type": "fixture",
        "path": "suites/integration/fixtures/build-to-verify"
      },
      "expectations": [
        {
          "type": "file_exists",
          "path": ".specwright/work/test-work/evidence/build-report.md",
          "description": "Build gate evidence file exists"
        },
        {
          "type": "snapshot_file_exists",
          "path": ".specwright/work/test-work/stage-report.md",
          "snapshot_index": 0,
          "description": "sw-build writes a stage report before verify"
        },
        {
          "type": "snapshot_file_contains",
          "path": ".specwright/work/test-work/stage-report.md",
          "pattern": "^Attention required:",
          "snapshot_index": 0,
          "description": "sw-build stage report starts with attention-required"
        },
        {
          "type": "snapshot_file_line_count_lte",
          "path": ".specwright/work/test-work/stage-report.md",
          "max_lines": 40,
          "snapshot_index": 0,
          "description": "sw-build stage report stays within the line cap"
        },
        {
          "type": "step_transcript_final_block",
          "step_index": 0,
          "line_patterns": [
            "^Done\\.\\s+.+\\.$",
            "^Artifacts:\\s+.+/$",
            "^Next:\\s+/sw-[a-z\\-]+$"
          ],
          "description": "sw-build emits machine-parseable three-line handoff"
        },
        {
          "type": "file_exists",
          "path": ".specwright/work/test-work/evidence/spec-compliance.md",
          "description": "Spec compliance evidence file exists"
        },
        {
          "type": "step_transcript_final_block",
          "step_index": 1,
          "line_patterns": [
            "^Done\\.\\s+.+\\.$",
            "^Artifacts:\\s+.+/$",
            "^Next:\\s+/sw-[a-z\\-]+$"
          ],
          "description": "sw-verify emits machine-parseable three-line handoff"
        },
        {
          "type": "model_grade",
          "rubric": "The combined transcript demonstrates disciplined pipeline behavior: build reports completion, verify reports gate results, and the user-facing messages stay concise with artifact paths and explicit next steps. Score 0.8+ when both stages are operationally clear and machine-parseable, 0.5-0.7 for partial structure, below 0.5 for missing or noisy handoffs.",
          "target": "$TRANSCRIPT",
          "description": "Transcript quality for build-to-verify handoff"
        },
        {
          "type": "gate_results",
          "expected": {"spec": "PASS"},
          "description": "Spec gate passes after verify"
        },
        {
          "type": "model_grade",
          "rubric": "The evidence files demonstrate thorough gate coverage: build evidence shows command output, spec compliance maps each acceptance criterion to implementation and test evidence with file:line references. The verdict includes reasoning, not just pass/fail. Score 0.8+ if all gates have evidence with specifics, 0.5-0.7 if evidence exists but is shallow, below 0.5 if evidence is missing or generic.",
          "target": ".specwright/work/test-work/evidence/spec-compliance.md",
          "description": "Evidence completeness and quality"
        }
      ],
      "tags": ["integration", "build-verify", "handoff"]
    },
    {
      "id": "doctor-to-status-repair-report",
      "layer": "integration",
      "sequence": ["sw-doctor", "sw-status"],
      "prompt_args": {
        "repair_unit_id": "zz-unconfirmed-shipped-fixture",
        "headless": true
      },
      "seed": {
        "type": "fixture",
        "path": "suites/integration/fixtures/doctor-to-status-repair"
      },
      "expectations": [
        {
          "type": "step_transcript_contains",
          "step_index": 0,
          "pattern": "sw-status --repair zz-unconfirmed-shipped-fixture",
          "description": "sw-doctor surfaces the inline repair command"
        },
        {
          "type": "snapshot_state",
          "field": "workUnits.0.status",
          "expected": "shipped",
          "snapshot_index": 0,
          "description": "sw-doctor backfill never mutates shipped status when it cannot prove a PR"
        },
        {
          "type": "snapshot_state",
          "field": "workUnits.0.prNumber",
          "expected": null,
          "snapshot_index": 0,
          "description": "sw-doctor leaves prNumber null when no PR is provable"
        },
        {
          "type": "step_transcript_contains",
          "step_index": 1,
          "pattern": "report-only|interactive",
          "description": "headless sw-status --repair reports next steps instead of mutating state"
        },
        {
          "type": "snapshot_state",
          "field": "workUnits.0.status",
          "expected": "shipped",
          "snapshot_index": 1,
          "description": "headless repair path leaves status unchanged"
        },
        {
          "type": "snapshot_state",
          "field": "workUnits.0.prNumber",
          "expected": null,
          "snapshot_index": 1,
          "description": "headless repair path leaves prNumber unchanged"
        },
        {
          "type": "model_grade",
          "rubric": "The transcript should clearly explain the STATE_DRIFT finding, show the exact remediation command, and make the headless/report-only limitation explicit. Score 0.8+ for precise operational guidance, 0.5-0.7 for partial guidance, below 0.5 for vague or missing repair instructions.",
          "target": "$TRANSCRIPT",
          "description": "Transcript quality for drift repair guidance"
        }
      ],
      "tags": ["integration", "doctor-status", "state-drift", "behavioral"]
    }
  ]
}
