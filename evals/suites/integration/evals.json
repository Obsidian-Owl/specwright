    {
      "id": "doctor-to-status-repair-report",
      "layer": "integration",
      "sequence": ["sw-doctor", "sw-status"],
      "prompt_args": {
        "repair_unit_id": "zz-unconfirmed-shipped-fixture",
        "headless": true
      },
      "seed": {
        "type": "fixture",
        "path": "suites/integration/fixtures/doctor-to-status-repair"
      },
      "expectations": [
        {
          "type": "step_transcript_contains",
          "step_index": 0,
          "pattern": "sw-status --repair zz-unconfirmed-shipped-fixture",
          "description": "sw-doctor surfaces the inline repair command"
        },
        {
          "type": "snapshot_state",
          "field": "workUnits.0.status",
          "expected": "shipped",
          "snapshot_index": 0,
          "description": "sw-doctor backfill never mutates shipped status when it cannot prove a PR"
        },
        {
          "type": "snapshot_state",
          "field": "workUnits.0.prNumber",
          "expected": null,
          "snapshot_index": 0,
          "description": "sw-doctor leaves prNumber null when no PR is provable"
        },
        {
          "type": "step_transcript_contains",
          "step_index": 1,
          "pattern": "report-only|interactive",
          "description": "headless sw-status --repair reports next steps instead of mutating state"
        },
        {
          "type": "snapshot_state",
          "field": "workUnits.0.status",
          "expected": "shipped",
          "snapshot_index": 1,
          "description": "headless repair path leaves status unchanged"
        },
        {
          "type": "snapshot_state",
          "field": "workUnits.0.prNumber",
          "expected": null,
          "snapshot_index": 1,
          "description": "headless repair path leaves prNumber unchanged"
        },
        {
          "type": "model_grade",
          "rubric": "The transcript should clearly explain the STATE_DRIFT finding, show the exact remediation command, and make the headless/report-only limitation explicit. Score 0.8+ for precise operational guidance, 0.5-0.7 for partial guidance, below 0.5 for vague or missing repair instructions.",
          "target": "$TRANSCRIPT",
          "description": "Transcript quality for drift repair guidance"
        }
      ],
      "tags": ["integration", "doctor-status", "state-drift", "behavioral"]
    },
