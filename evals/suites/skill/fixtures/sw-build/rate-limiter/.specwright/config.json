{
  "version": "2.0",
  "project": {
    "name": "rate-limiter",
    "type": "node",
    "languages": ["typescript"],
    "testRunner": "vitest"
  },
  "commands": {
    "build": "npx tsc --noEmit",
    "test": "npx vitest run"
  },
  "git": {
    "defaultBranch": "main",
    "strategy": "trunk-based",
    "conventionalCommits": true,
    "branchPrefix": "work/"
  },
  "gates": {
    "build": { "enabled": true },
    "tests": { "enabled": true },
    "spec": { "enabled": true }
  }
}
