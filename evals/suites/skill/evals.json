    {
      "id": "sw-build-malformed-spec",
      "layer": "skill",
      "skill": "sw-build",
      "prompt_template": "build",
      "prompt_args": {},
      "expected_behavior": "refuse_or_warn",
      "seed": {
        "type": "fixture",
        "path": "suites/skill/fixtures/sw-build/malformed-spec"
      },
      "expectations": [
        {
          "type": "file_not_exists",
          "path": "src/auth.ts",
          "description": "Build should NOT produce implementation files from a spec with no ACs"
        },
        {
          "type": "model_grade",
          "rubric": "The build output indicates that the spec is deficient — missing acceptance criteria, unable to proceed, or similar. The build should NOT silently produce implementation code. Score 0.8+ if explicitly mentions missing/absent acceptance criteria. Score 0.5-0.7 if mentions spec is incomplete. Below 0.5 if silently proceeds.",
          "target": "$TRANSCRIPT",
          "description": "Build recognizes the spec deficiency"
        }
      ],
      "tags": ["skill", "sw-build", "negative", "malformed-spec"]
    },
    {
      "id": "sw-debug-known-bug",
      "skill": "sw-debug",
      "prompt_template": "debug",
      "prompt_args": {
        "error_output": "Test failure: processor.test.ts\n  FAIL: processes all elements\n    Expected: [2, 4, 6, 8, 10]\n    Received: [2, 4, 6, 8]\n    Last element (5) was not processed."
      },
      "seed": {
        "type": "fixture",
        "path": "suites/skill/fixtures/sw-debug/known-bug"
      },
      "expectations": [
        {
          "type": "file_contains",
          "path": "src/processor.ts",
          "pattern": "i\\s*<\\s*numbers\\.length\\s*[;)]|i\\s*<=\\s*numbers\\.length\\s*-\\s*1",
          "description": "Off-by-one bug is fixed (loop includes last element)"
        },
        {
          "type": "model_grade",
          "rubric": "The diagnosis identifies the off-by-one error in processor.ts — specifically that the loop condition `i < numbers.length - 1` skips the last element. The fix changes the loop to include all elements. Score 0.8+ if root cause identified at correct file/line with correct fix. Score 0.5-0.7 if root cause identified but fix is indirect. Below 0.5 if root cause is missed.",
          "target": "$TRANSCRIPT",
          "threshold": 0.6,
          "description": "Diagnosis quality: identifies off-by-one root cause"
        }
      ],
      "tags": ["skill", "sw-debug", "off-by-one", "diagnostic-quality"]
    },
    {
      "id": "sw-audit-planted-debt",
      "skill": "sw-audit",
      "prompt_template": "audit",
      "prompt_args": {},
      "seed": {
        "type": "fixture",
        "path": "suites/skill/fixtures/sw-audit/planted-debt"
      },
      "expectations": [
        {
          "type": "file_exists",
          "path": ".specwright/AUDIT.md",
          "description": "Audit produces AUDIT.md findings file"
        },
        {
          "type": "model_grade",
          "rubric": "The AUDIT.md identifies at least 2 of these 3 planted issues: (1) circular dependency between moduleA.ts and moduleB.ts, (2) unused exported function unusedHelper in utils.ts, (3) inconsistent file naming — order_handler.ts uses snake_case violating the constitution's camelCase rule. Each finding should have a severity classification. Score 0.8+ if 2+ found with severity, 0.5-0.7 if 1 found, below 0.5 if none found.",
          "target": ".specwright/AUDIT.md",
          "threshold": 0.6,
          "description": "Audit finding accuracy: identifies planted architectural issues"
        }
      ],
      "tags": ["skill", "sw-audit", "architectural-debt", "planted-issues"]
    },
    {
      "id": "sw-build-rate-limiter",
      "skill": "sw-build",
      "prompt_template": "build",
      "prompt_args": {},
      "seed": {
        "type": "fixture",
        "path": "suites/skill/fixtures/sw-build/rate-limiter"
      },
      "expectations": [
        {
          "type": "file_exists",
          "path": "src/rate-limiter.ts",
          "description": "Rate limiter implementation file created"
        },
        {
          "type": "tests_pass",
          "command": "npx vitest run",
          "description": "All tests pass after implementation"
        },
        {
          "type": "model_grade",
          "rubric": "The tester agent wrote tests that include: (1) boundary conditions — consuming exactly capacity tokens, consuming 0 available tokens, refill to exactly capacity (never exceeds). (2) Error path tests — negative capacity config, zero tokens consume attempt. (3) At least one test designed to catch a hardcoded implementation — e.g., testing multiple different consume amounts or verifying token count changes after consume. Score 0.8+ if all 3 present, 0.5-0.7 if 2 of 3, below 0.5 if only happy path.",
          "target": "$TRANSCRIPT",
          "threshold": 0.6,
          "description": "Subagent quality: tester adversarial test coverage"
        },
        {
          "type": "model_grade",
          "rubric": "The executor agent's rate limiter implementation: (1) uses no external dependencies beyond the TypeScript standard library, (2) correctly handles the refill-over-time logic without race conditions in the calculation, (3) does not include features beyond what the spec requires (no HTTP middleware, no Redis integration, no async patterns unless spec demands them). Score 0.8+ if minimal and correct, 0.5-0.7 if correct but over-engineered, below 0.5 if incorrect or missing spec requirements.",
          "target": "$TRANSCRIPT",
          "threshold": 0.6,
          "description": "Subagent quality: executor implementation discipline"
        }
      ],
      "tags": ["skill", "sw-build", "rate-limiter", "subagent-quality", "non-trivial"]
    },
