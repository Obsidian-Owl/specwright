# Specwright project artifacts under the repo root stay on an explicit allowlist.
# The root-anchored pattern avoids accidentally affecting fixture `.specwright/`
# trees elsewhere in the repository.
/.specwright/*
!/.specwright/*.md
!/.specwright/config.json
!/.specwright/research/
!/.specwright/research/**
!/.specwright/learnings/
!/.specwright/learnings/**
!/.specwright/works/
!/.specwright/works/**
/.specwright/state/
/.specwright/work/
/.specwright/worktrees/
/.specwright-local/
.claude/
!.claude/commands/

# Runtime state files
.orphaned_at

# Build output
dist/

# OS
.DS_Store

# Python
__pycache__/
*.pyc

# Secrets and credentials
.env
.env.*
*.pem
*.key
*.secret

# Plugin working directories
.omc/

# Eval framework results
evals/results/
